    {
      "name": "08 Update by id - set disabled",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/flags/{{featureId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"featureName\": \"NEW_CHECKOUT\",\n  \"enabled\": false,\n  \"strategy\": \"COUNTRY\",\n  \"rules\": { \"country\": \"IN\" }\n}"
        }
      }
    },
    {
