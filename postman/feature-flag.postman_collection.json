  },
  "item": [
    {
      "name": "01 Create COUNTRY flag - happy path",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/flags",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"featureName\": \"NEW_CHECKOUT\",\n  \"enabled\": true,\n  \"strategy\": \"COUNTRY\",\n  \"rules\": { \"country\": \"IN\" }\n}"
        }
      }
    },
    {
      "name": "02 Create USER flag - happy path",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/flags",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"featureName\": \"UPI_ROLLOUT\",\n  \"enabled\": true,\n  \"strategy\": \"USER\",\n  \"rules\": { \"userId\": \"user-123\" }\n}"
        }
      }
    },
    {
      "name": "03 Create PERCENTAGE flag - happy path",
